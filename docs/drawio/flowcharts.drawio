        <mxCell id="e4_2_no" value="Không" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p4_dec_exist" target="p4_err_404"><mxGeometry relative="1" as="geometry"/></mxCell>

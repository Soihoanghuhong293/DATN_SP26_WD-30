        <mxCell id="e4_3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="1" source="p4_prepare" target="p4_dec_passengers"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4_3_yes" value="Có" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p4_dec_passengers" target="p4_check_group"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4_3_no" value="Không" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p4_dec_passengers" target="p4_update"><mxGeometry relative="1" as="geometry"/></mxCell>

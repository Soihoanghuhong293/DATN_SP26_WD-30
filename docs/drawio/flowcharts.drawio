        </mxCell>
        <mxCell id="p4_find" value="Tìm đặt chỗ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="145" width="190" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p4_dec_exist" value="Tồn tại?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="105" y="220" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p4_err_404" value="Thông báo lỗi&#xa;404" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="300" y="235" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p4_prepare" value="Chuẩn bị updateData&#xa;+ logsToAdd" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="60" y="325" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_dec_passengers" value="Có cập nhật&#xa;hành khách?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="105" y="405" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p4_check_group" value="Kiểm tra: hành khách&#xa;&lt;= groupSize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="300" y="415" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_err_group" value="Thông báo lỗi&#xa;DS khách vượt groupSize" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="520" y="415" width="230" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_log_passengers" value="Đặt hành khách&#xa;+ ghi log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="495" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_update" value="Cập nhật đặt chỗ&#xa;($set + $ghi logs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="515" width="190" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_dec_guide" value="guide_id&#xa;thay đổi?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="105" y="605" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p4_mail_assign" value="Gửi email phân công&#xa;HDV mới (nếu đủ điều kiện)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="300" y="605" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p4_mail_unassign" value="Gửi email gỡ phân công&#xa;HDV cũ (nếu có)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="560" y="605" width="210" height="70" as="geometry"/>
        </mxCell>

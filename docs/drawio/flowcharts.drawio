          <mxGeometry x="105" y="715" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p4_alloc" value="Try auto allocate&#xa;cars + rooms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="300" y="725" width="190" height="60" as="geometry"/>

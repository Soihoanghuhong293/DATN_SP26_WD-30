  <diagram id="p3" name="03 - Payment - SePay VietQR">
    <mxGraphModel dx="2200" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p3_title" value="Sơ đồ: SePay VietQR (GET /sepay/qr/:id + POST /sepay/webhook)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="35" y="22" width="1200" height="30" as="geometry"/>
        </mxCell>

        <!-- Lane 1: tạo QR -->
        <mxCell id="p3_start" value="Bắt đầu" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="81" y="90" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p3_req_qr" value="Client gọi&#xa;GET /sepay/qr/:id&#xa;?loại thanh toán=đặt cọc|còn lại|toàn bộ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="46" y="174" width="190" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="p3_find_booking" value="Tìm đặt chỗ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="46" y="286" width="190" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p3_dec_exist" value="Tồn tại?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="98" y="370" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p3_err_404" value="Thông báo lỗi&#xa;404" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="299" y="381" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p3_calc" value="Tính số tiền cần trả&#xa;theo loại thanh toán" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="46" y="493" width="190" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p3_build_qr" value="nội dung chuyển khoản = SP&lt;bookingId&gt;&#xa;Tạo liên kết QR VietQR&#xa;Trả 200 (QR + content)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="46" y="577" width="190" height="85" as="geometry"/>
        </mxCell>

        <!-- Lane 2: webhook -->
        <mxCell id="p3_pay" value="Khách chuyển khoản&#xa;đúng nội dung SP&lt;bookingId&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="598" y="174" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p3_webhook" value="SePay gửi&#xa;POST /sepay/webhook" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="801" y="280" width="190" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p3_parse" value="Parse transactionContent&#xa;+ số tiền nhận + referenceCode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="801" y="370" width="190" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="p3_dec_amount" value="số tiền nhận &gt; 0?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="853" y="470" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p3_ack_skip1" value="ACK 200&#xa;Bỏ qua" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1054" y="482" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p3_dec_match" value="Match SP&lt;mã&gt;?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="853" y="582" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="p3_ack_skip2" value="ACK 200&#xa;Bỏ qua" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1054" y="594" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="p3_update_pay" value="Tìm đặt chỗ&#xa;So sánh số tiền nhận vs total&#xa;Đặt trạng thái thanh toán (đã thanh toán/đặt cọc)&#xa;ghi log + lưu" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="598" y="700" width="230" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="p3_end" value="Kết thúc" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="836" y="834" width="130" height="50" as="geometry"/>

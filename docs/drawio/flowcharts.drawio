        <mxCell id="e3_w1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="1" source="p3_pay" target="p3_webhook"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3_w2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="1" source="p3_webhook" target="p3_parse"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3_w3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="1" source="p3_parse" target="p3_dec_amount"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3_w3_no" value="Không" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p3_dec_amount" target="p3_ack_skip1"><mxGeometry relative="1" as="geometry"/></mxCell>

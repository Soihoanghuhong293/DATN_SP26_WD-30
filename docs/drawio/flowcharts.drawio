        <mxCell id="e3_3_no" value="Không" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p3_dec_exist" target="p3_err_404"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3_3_yes" value="Có" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p3_dec_exist" target="p3_calc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3_4" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="1" source="p3_calc" target="p3_build_qr"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3_lane" value="Sau khi khách chuyển khoản" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=12;" edge="1" parent="1" source="p3_build_qr" target="p3_pay">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">

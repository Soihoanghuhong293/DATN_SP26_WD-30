  <diagram id="adm-00-mucluc" name="00 – Mục lục (đối chiếu tổng quát)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="Z-t" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=14;fontStyle=1;fontColor=#000000;" value="ViGo — Phân rã UC chi tiết (Admin + Khách + HDV)" vertex="1">
          <mxGeometry x="40" y="30" width="560" height="28" as="geometry" />
        </mxCell>
        <mxCell id="Z-b" parent="1" style="text;html=1;strokeColor=none;fillColor=#fffce6;align=left;fontSize=10;spacing=6;fontColor=#000000;" value="&amp;lt;b&amp;gt;Tổng 24 sheet.&amp;lt;/b&amp;gt; Admin 00–12: nét liền tác nhân–UC; nét đứt &amp;lt;&amp;lt;include&amp;gt;&amp;gt;/&amp;lt;&amp;lt;extend&amp;gt;&amp;gt; như mẫu giảng dạy.&amp;lt;br&amp;gt;&amp;lt;b&amp;gt;Admin:&amp;lt;/b&amp;gt; 01 booking, 02 tour &amp;amp; lịch KH, 03 mẫu tour, 04 danh mục &amp;amp; NCC, 05 quản trị HDV, 06 người dùng, 07 đánh giá, 08 liên hệ, 09 giá lễ, 10 xếp chỗ, 11 dashboard, 12 cấu hình.&amp;lt;br&amp;gt;&amp;lt;b&amp;gt;Khách:&amp;lt;/b&amp;gt; 20 đăng ký/ĐN/ĐX, 21 tìm &amp;amp; lọc tour, 22 chi tiết tour, 23 yêu thích, 24 đặt tour, 25 thanh toán, 26 đơn đặt, 27 đánh giá, 28 liên hệ tư vấn.&amp;lt;br&amp;gt;&amp;lt;b&amp;gt;HDV (hướng dẫn viên):&amp;lt;/b&amp;gt; 30 portal &amp;amp; booking giao, 31 chuyến lịch &amp;amp; cài đặt." vertex="1">
          <mxGeometry x="40" y="65" width="820" height="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

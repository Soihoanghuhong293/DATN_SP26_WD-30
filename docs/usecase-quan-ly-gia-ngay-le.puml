@startuml usecase_quan_ly_gia_ngay_le
title Use case — Quản lý giá ngày lễ (Admin)
skinparam actorStyle awesome
left to right direction

actor "Admin" as ADM

usecase "Quản lý giá ngày lễ" as UC_ROOT 

usecase "Xem danh sách cấu hình\nvà áp dụng bộ lọc" as UC_LIST
usecase "Thêm cấu hình giá ngày lễ" as UC_CREATE
usecase "Sửa cấu hình giá ngày lễ" as UC_EDIT
usecase "Xóa cấu hình giá ngày lễ" as UC_DELETE

usecase "Tải danh sách cấu hình\n(GET /holiday-pricings)" as UC_LOAD
usecase "Lọc theo từ khóa / tour /\nkhoảng ngày / loại giá\n(cố định / hệ số)" as UC_FILTER

usecase "Tải danh sách tour\n(chọn tour áp dụng)" as UC_TOURS
usecase "Tải một cấu hình\n(GET /holiday-pricings/:id)" as UC_FETCH
usecase "Gửi lưu cấu hình\n(POST / PUT)" as UC_SAVE

usecase "Xác nhận trước khi xóa" as UC_CONFIRM

UC_ROOT <|-- UC_LIST
UC_ROOT <|-- UC_CREATE
UC_ROOT <|-- UC_EDIT
UC_ROOT <|-- UC_DELETE

ADM --> UC_ROOT



UC_LIST ..> UC_LOAD : <<include>>
UC_LIST <.. UC_FILTER : <<extend>>

UC_CREATE ..> UC_TOURS : <<include>>
UC_CREATE ..> UC_SAVE : <<include>>

UC_EDIT ..> UC_TOURS : <<include>>
UC_EDIT ..> UC_FETCH : <<include>>
UC_EDIT ..> UC_SAVE : <<include>>

UC_LIST <.. UC_DELETE : <<extend>>
UC_DELETE ..> UC_CONFIRM : <<include>>

@enduml

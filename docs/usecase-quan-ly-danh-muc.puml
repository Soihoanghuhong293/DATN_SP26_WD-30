@startuml usecase_quan_ly_danh_muc
title Use case — Quản lý danh mục (Admin)
skinparam actorStyle awesome
left to right direction

actor "Admin" as ADM

usecase "Quản lý danh mục" as UC_ROOT 

usecase "Xem cây danh mục\nvà thống kê (tổng / hoạt động)" as UC_LIST
usecase "Thêm danh mục mới" as UC_CREATE
usecase "Sửa danh mục" as UC_EDIT
usecase "Xóa danh mục" as UC_DELETE

usecase "Tải cây danh mục\n(getCategoryTree)" as UC_LOAD
usecase "Lọc theo từ khóa /\ntrạng thái (active / inactive)" as UC_FILTER

usecase "Tải chi tiết danh mục\n(getCategory)" as UC_FETCH
usecase "Kiểm tra form\nvà gửi lưu\n(create / updateCategory)" as UC_SAVE

usecase "Xác nhận trước khi xóa" as UC_CONFIRM

UC_ROOT <|-- UC_LIST
UC_ROOT <|-- UC_CREATE
UC_ROOT <|-- UC_EDIT
UC_ROOT <|-- UC_DELETE

ADM --> UC_ROOT



UC_LIST ..> UC_LOAD : <<include>>
UC_LIST <.. UC_FILTER : <<extend>>

UC_CREATE ..> UC_SAVE : <<include>>
UC_EDIT ..> UC_FETCH : <<include>>
UC_EDIT ..> UC_SAVE : <<include>>

UC_LIST <.. UC_DELETE : <<extend>>
UC_DELETE ..> UC_CONFIRM : <<include>>

@enduml
